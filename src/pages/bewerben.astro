---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jetzt Bewerben">
  <section class="pt-24 pb-12 md:pt-40 md:pb-20 px-6 md:px-24">
    <p class="text-brand font-bold uppercase tracking-[0.3em] mb-4 text-[10px] md:text-xs italic">Karriere</p>
    <h1 class="text-[clamp(2.5rem,10vw,6rem)] font-black uppercase leading-[0.9] mb-8">
      Teil des <br />
      <span class="stroke-black">Teams werden.</span>
    </h1>
  </section>

  <section class="pb-20 md:pb-32 px-6 md:px-24">
    <div class="max-w-4xl bg-slate-50 p-6 md:p-14 border border-slate-100">

      <!-- Success message (hidden by default) -->
      <div id="success-msg" class="hidden mb-8 bg-[#0d1b2a] text-white p-6 border-l-4 border-brand">
        <p class="font-black uppercase text-sm mb-1">Bewerbung erfolgreich gesendet!</p>
        <p class="text-slate-300 text-xs font-medium">Wir melden uns so schnell wie möglich bei Ihnen.</p>
      </div>

      <!-- Error message (hidden by default) -->
      <div id="error-msg" class="hidden mb-8 bg-red-50 text-red-800 p-6 border-l-4 border-red-500">
        <p class="font-black uppercase text-sm mb-1">Fehler beim Senden.</p>
        <p class="text-red-600 text-xs font-medium">Bitte versuchen Sie es erneut oder schreiben Sie uns direkt.</p>
      </div>

      <form id="apply-form" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

        <div class="flex flex-col gap-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Vor- & Nachname *</label>
          <input type="text" name="name" required class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold text-sm" />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">E-Mail *</label>
          <input type="email" name="email" required class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold text-sm" />
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Telefonnummer *</label>
          <input
            type="tel"
            name="phone"
            required
            class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold text-sm"
            placeholder="+49 176 12345678"
          />
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Bewerbung als</label>
          <input
            type="text"
            id="job-input"
            name="position"
            readonly
            class="bg-slate-100 border-b-2 border-slate-300 py-2 md:py-3 px-2 outline-none font-black uppercase text-sm text-slate-500 cursor-not-allowed"
          />
        </div>

        <!-- CV Upload -->
        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Lebenslauf hochladen (PDF, max. 5 MB)</label>
          <label id="cv-label" class="flex items-center gap-4 border-2 border-dashed border-slate-200 p-4 md:p-6 cursor-pointer hover:border-brand transition-colors group">
            <span class="bg-[#0d1b2a] text-white px-4 py-2 text-[10px] font-black uppercase tracking-widest group-hover:bg-brand transition-colors whitespace-nowrap">
              Datei auswählen
            </span>
            <span id="cv-filename" class="text-xs font-bold text-slate-400 uppercase truncate">Keine Datei ausgewählt</span>
            <input type="file" name="cv" id="cv-input" accept=".pdf,.doc,.docx" class="hidden" />
          </label>
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Nachricht (Optional)</label>
          <textarea name="message" rows="3" class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-medium text-sm resize-none" placeholder="Kurze Vorstellung oder weitere Hinweise..."></textarea>
        </div>

        <div class="md:col-span-2 pt-4 md:pt-6">
          <button id="submit-btn" type="submit" class="w-full bg-[#0d1b2a] text-white py-4 md:py-5 font-black uppercase tracking-[0.2em] hover:bg-brand transition-all flex justify-between px-6 md:px-8 items-center group text-sm">
            <span id="btn-text">Bewerbung absenden</span>
            <span id="btn-arrow" class="group-hover:translate-x-2 transition-transform">→</span>
          </button>
        </div>
      </form>
    </div>
  </section>
</Layout>

<script>
  // Pre-fill position from URL
  const urlParams = new URLSearchParams(window.location.search);
  const jobTitle = urlParams.get('job');
  const jobInput = document.getElementById('job-input') as HTMLInputElement;

  if (jobTitle && jobInput) {
    jobInput.value = jobTitle.toUpperCase();
  } else if (jobInput) {
    jobInput.value = 'INITIATIVBEWERBUNG';
    jobInput.readOnly = false;
    jobInput.classList.remove('cursor-not-allowed', 'bg-slate-100');
  }

  // Show selected filename
  const cvInput = document.getElementById('cv-input') as HTMLInputElement;
  const cvFilename = document.getElementById('cv-filename') as HTMLElement;
  cvInput?.addEventListener('change', () => {
    const file = cvInput.files?.[0];
    cvFilename.textContent = file ? file.name : 'Keine Datei ausgewählt';
  });

  // Handle form submission
  const form = document.getElementById('apply-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const successMsg = document.getElementById('success-msg') as HTMLElement;
  const errorMsg = document.getElementById('error-msg') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validate file size (5 MB max)
    const file = cvInput?.files?.[0];
    if (file && file.size > 5 * 1024 * 1024) {
      alert('Die Datei ist zu groß. Maximale Größe: 5 MB.');
      return;
    }

    submitBtn.disabled = true;
    btnText.textContent = 'Wird gesendet...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const res = await fetch('/api/apply', { method: 'POST', body: formData });

      if (res.ok) {
        form.reset();
        cvFilename.textContent = 'Keine Datei ausgewählt';
        successMsg.classList.remove('hidden');
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Bewerbung absenden';
    }
  });
</script>
