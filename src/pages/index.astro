---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: "1",
    title: "Reinigungsservice",
    image: "/projekte/WASWIRTUNReinigungservice.jpg"
  },
  {
    id: "2",
    title: "Hausmeisterservice",
    image: "/projekte/WASWIRTUNHausmeisterservice.jpg"
  },
  {
    id: "3",
    title: "Umzugsservice",
    image: "/projekte/WASWIRTUNUmzugsserviice.jpg"
  },
  {
    id: "4",
    title: "Gartenservice",
    image: "/projekte/WASWIRTUNGartenservice.jpg"
  }
];
---

<Layout title="Zuverlässige Dienstleistungen in Kirn">
    <section class="w-full relative p-0 mb-3 md:mb-20 overflow-hidden">
    <video autoplay muted loop playsinline class="w-full h-auto block">
        <source src="/main.mp4" type="video/mp4" />
    </video>
    <div class="mouse-wrapper">
        <div class="mouse"></div>
        <p class="text-[9px] font-bold uppercase tracking-[0.3em] text-white/60">Scroll</p>
    </div>
</section>

<section class="relative min-h-[80vh] flex flex-col justify-center px-6 md:px-24 pt-10 pb-20 md:py-20">
    <div class="max-w-6xl">
        <p class="text-brand font-bold uppercase tracking-[0.3em] mb-4 text-[10px] md:text-xs">Attar Dienstleistungen</p>
        <h1 class="text-[clamp(2.2rem,10vw,8rem)] font-black mb-6 md:mb-8 leading-[1.1] md:leading-[0.9] text-[#0d1b2a]">
            Ein Partner<br />
            <span class="block mt-3 stroke-dark">Alle Lösungen.</span>
        </h1>

        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-end">
            <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
                Chaos bewältigen, Werte erhalten, Freiraum schaffen. Wir nehmen Ihr Projekt in die Hand – zuverlässig, diskret und mit höchstem Anspruch.
            </p>
            <a href="/kontakt" class="group flex items-center gap-4 text-xl md:text-2xl font-black uppercase italic text-[#0d1b2a] w-fit">
                Angebot anfragen
                <span class="bg-brand text-white p-2 md:p-3 rounded-full group-hover:bg-[#0d1b2a] transition-all duration-300">
                   <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover:translate-x-1 transition-transform">
                      <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"/>
                   </svg>
                </span>
            </a>
        </div>
    </div>
</section>

<section class="px-6 md:px-24 py-20 md:py-32 bg-[#0d1b2a] text-white">
  <h2 class="text-brand text-[10px] md:text-xs font-bold uppercase tracking-widest mb-10 md:mb-12 italic">Kundenstimmen</h2>
  <div class="grid md:grid-cols-3 gap-10 md:gap-8">
    {[
      { name: "M. Schmidt", text: "Die Entrümpelung verlief absolut reibungslos – diskret, schnell und ohne Stress. Klare Empfehlung!" },
      { name: "K. Weber", text: "Unser Garten sah noch nie so gepflegt aus. Ein zuverlässiges Team, das wirklich mitdenkt." },
      { name: "Hausverwaltung Meyer", text: "Professioneller Hausmeisterservice auf höchstem Niveau. Absolut vertrauenswürdig." }
    ].map((review) => (
      <div class="border-l-2 border-brand/40 pl-6 md:pl-8 py-2">
        <p class="text-base md:text-lg mb-4 md:mb-6 italic text-slate-300 leading-relaxed">"{review.text}"</p>
        <p class="font-black uppercase tracking-widest text-brand text-xs md:text-sm">— {review.name}</p>
      </div>
    ))}
  </div>
</section>

<section class="px-6 md:px-24 py-20 md:py-32 bg-slate-50 overflow-hidden">
    <div class="flex justify-between items-end mb-10 md:mb-12">
        <div>
            <p class="text-brand font-bold uppercase tracking-[0.3em] mb-4 text-xs italic">Unsere Leistungen</p>
            <h2 class="text-4xl md:text-5xl font-black uppercase text-[#0d1b2a]">Was wir tun.</h2>
        </div>

        <div class="hidden md:flex gap-2">
            <button class="swiper-prev-btn group cursor-pointer border-2 border-[#0d1b2a] p-3 hover:bg-[#0d1b2a] transition-all" aria-label="Zurück">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="stroke-[#0d1b2a] group-hover:stroke-white transition-colors">
                    <path d="M19 12H5M5 12L11 6M5 12L11 18" stroke-width="3" stroke-linecap="square"/>
                </svg>
            </button>
            <button class="swiper-next-btn group cursor-pointer border-2 border-[#0d1b2a] p-3 hover:bg-[#0d1b2a] transition-all" aria-label="Weiter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="stroke-[#0d1b2a] group-hover:stroke-white transition-colors">
                    <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke-width="3" stroke-linecap="square"/>
                </svg>
            </button>
        </div>
    </div>

    <div class="swiper-services !overflow-visible">
        <div class="swiper-wrapper">
            {services.map((service, index) => (
              <div class="swiper-slide h-auto">
                <a href="/dienstleistungen" class="relative bg-[#0d1b2a] aspect-[4/5] flex flex-col justify-between group cursor-pointer h-full overflow-hidden border border-slate-200 block">
                  <div class="absolute inset-0 z-0 overflow-hidden bg-white">
                    <img src={service.image} alt={service.title} class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-all duration-700 ease-out" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0d1b2a]/80 via-[#0d1b2a]/10 to-transparent"></div>
                  </div>

                  <div class="relative z-10 p-8 md:p-10 flex flex-col justify-between h-full text-center items-center">
                    <span class="text-5xl md:text-6xl font-black text-white/20 group-hover:text-brand transition-all duration-500 italic leading-none">0{index + 1}</span>
                    <div class="space-y-3 w-full">
                      <h3 class="text-2xl md:text-3xl font-black uppercase leading-[0.9] text-white">{service.title}</h3>
                      <div class="h-1 bg-brand mx-auto transition-all duration-500 w-0 group-hover:w-2/3"></div>
                    </div>
                  </div>
                </a>
              </div>
            ))}
        </div>
    </div>

    <div class="mt-8 flex justify-center gap-2 md:hidden">
        <button class="swiper-prev-btn group cursor-pointer border-2 border-[#0d1b2a] p-3 hover:bg-[#0d1b2a] transition-all" aria-label="Zurück">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="stroke-[#0d1b2a] group-hover:stroke-white transition-colors">
                <path d="M19 12H5M5 12L11 6M5 12L11 18" stroke-width="3" stroke-linecap="square"/>
            </svg>
        </button>
        <button class="swiper-next-btn group cursor-pointer border-2 border-[#0d1b2a] p-3 hover:bg-[#0d1b2a] transition-all" aria-label="Weiter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="stroke-[#0d1b2a] group-hover:stroke-white transition-colors">
                <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke-width="3" stroke-linecap="square"/>
            </svg>
        </button>
    </div>
</section>

<section class="px-6 md:px-24 py-20 md:py-32 bg-[#0d1b2a] text-white">
    <div class="max-w-4xl">
        <h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase mb-6 md:mb-8 leading-tight">
            Ihre Anforderungen<br/>sind einzigartig?<br/>
            <span class="text-brand">Unsere Lösungen auch.</span>
        </h2>
        <p class="text-base md:text-lg text-slate-300 mb-3 max-w-2xl leading-relaxed">
            Wir erstellen individuelle Konzepte, die exakt auf Ihr Projekt zugeschnitten sind – flexibel, effizient und professionell umgesetzt.
        </p>
        <p class="text-sm text-slate-400 mb-10 max-w-2xl">
            Sprechen Sie uns an und erhalten Sie Ihr persönliches Angebot.
        </p>
        <a href="/kontakt" class="inline-block bg-brand text-white px-8 md:px-10 py-4 md:py-5 font-black uppercase tracking-widest hover:bg-white hover:text-[#0d1b2a] transition-colors text-sm">
            Jetzt individuelles Angebot sichern
        </a>
    </div>
</section>
</Layout>
<script>
import Swiper from 'swiper';
    import { Navigation } from 'swiper/modules';
    import 'swiper/css';

    new Swiper('.swiper-services', {
        modules: [Navigation],
        slidesPerView: 1.1,
        spaceBetween: 16,
        navigation: {
            nextEl: '.swiper-next-btn',
            prevEl: '.swiper-prev-btn',
        },
        breakpoints: {
            640: { slidesPerView: 2, spaceBetween: 16 },
            1024: {
                slidesPerView: 3,
                spaceBetween: 1
            },
        }
    });
    const mouseIcon = document.querySelector('.mouse-wrapper') as HTMLElement;

    window.addEventListener('scroll', () => {
        const scrollValue = window.scrollY;

        if (mouseIcon) {
            if (scrollValue > 0 && scrollValue < 150) {
                const moveAmount = scrollValue * 0.5;
                mouseIcon.style.transform = `translate(-50%, ${moveAmount}px)`;

                const fadeStart = 100;
				const newOpacity = 1 - (Math.max(0, scrollValue - fadeStart) / 200);
                mouseIcon.style.opacity = newOpacity.toString();
                mouseIcon.style.visibility = 'visible';
            }
            else if (scrollValue >= 150) {
                mouseIcon.style.opacity = '0';
                mouseIcon.style.visibility = 'hidden';
            }
            else {
                mouseIcon.style.transform = `translate(-50%, 0)`;
                mouseIcon.style.opacity = '1';
                mouseIcon.style.visibility = 'visible';
            }
        }
    });

</script>
