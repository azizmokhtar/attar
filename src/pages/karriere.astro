---
import Layout from '../layouts/Layout.astro';

const jobs = [
  {
    title: "Helfer Entrümpelung (m/w/d)",
    type: "Vollzeit",
    location: "Kirn & Umgebung",
    description: "Unterstützung bei Räumungen, Transporten und Entsorgung. Führerschein Klasse B von Vorteil."
  },
  {
    title: "Hausmeister (m/w/d)",
    type: "Vollzeit / Teilzeit",
    location: "Kirn & Umgebung",
    description: "Betreuung und Wartung von Wohn- und Gewerbeimmobilien. Handwerkliches Geschick erforderlich."
  },
  {
    title: "Gärtner / Grünpflegehelfer (m/w/d)",
    type: "Saisonal / Teilzeit",
    location: "Kirn & Umgebung",
    description: "Pflege von Außenanlagen, Rasenmähen, Heckenschnitt und Gartenarbeit. Erfahrung willkommen, aber nicht Voraussetzung."
  }
];
---

<Layout title="Karriere">
  <section class="pt-24 pb-12 md:pt-40 md:pb-20 px-6 md:px-24">
    <p class="text-brand font-bold uppercase tracking-[0.3em] mb-4 text-[10px] md:text-xs italic">Karriere</p>
    <h1 class="text-[clamp(2.5rem,10vw,6rem)] font-black uppercase leading-[0.9] mb-8">
      Werde Teil <br />
      <span class="block mt-2 md:mt-4 stroke-black">des Teams.</span>
    </h1>
  </section>

  <section class="px-6 md:px-24 py-14 md:py-20 bg-slate-50 border-y border-slate-100 grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-12">
    <div>
      <h3 class="font-black uppercase text-lg md:text-xl mb-3 md:mb-4 italic text-[#0d1b2a]">Faire Vergütung</h3>
      <p class="text-xs md:text-sm text-slate-600 leading-relaxed font-medium">Wir schätzen harte Arbeit und zahlen pünktlich, fair und über dem Marktdurchschnitt.</p>
    </div>
    <div>
      <h3 class="font-black uppercase text-lg md:text-xl mb-3 md:mb-4 italic text-[#0d1b2a]">Modernes Equipment</h3>
      <p class="text-xs md:text-sm text-slate-600 leading-relaxed font-medium">Professionelle Maschinen, hochwertige Arbeitskleidung und alles was du brauchst, um gute Arbeit zu leisten.</p>
    </div>
    <div>
      <h3 class="font-black uppercase text-lg md:text-xl mb-3 md:mb-4 italic text-[#0d1b2a]">Echtes Team</h3>
      <p class="text-xs md:text-sm text-slate-600 leading-relaxed font-medium">Bei uns bist du keine Nummer. Wir arbeiten auf Augenhöhe und unterstützen uns gegenseitig.</p>
    </div>
  </section>

  <section class="px-6 md:px-24 py-16 md:py-32">
    <h2 class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-brand mb-10 md:mb-16 italic">Offene Positionen</h2>

    <div class="flex flex-col border-t border-slate-200">
      {jobs.map((job) => (
        <div class="group border-b border-slate-200 py-8 md:py-12 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-center hover:bg-slate-50 transition-colors px-2 md:px-4">
          <div class="md:col-span-5">
            <h3 class="text-lg md:text-2xl font-black uppercase mb-1 md:mb-2">{job.title}</h3>
            <div class="flex gap-3 text-[9px] md:text-[10px] font-bold uppercase text-slate-400">
                <span>{job.type}</span>
                <span>•</span>
                <span>{job.location}</span>
            </div>
          </div>
          <div class="md:col-span-4">
            <p class="text-xs md:text-sm text-slate-600 font-medium leading-relaxed">{job.description}</p>
          </div>
          <div class="md:col-span-3 md:text-right">
            <a
              href={`/bewerben?job=${encodeURIComponent(job.title)}`}
              class="inline-block bg-[#0d1b2a] text-white px-6 py-3 md:px-8 md:py-4 font-black uppercase text-[9px] md:text-[10px] tracking-widest hover:bg-brand transition-all w-full md:w-auto text-center"
            >
                Jetzt bewerben
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="px-6 md:px-24 py-16 md:py-32 bg-white text-center">
    <div class="max-w-3xl mx-auto border-2 border-dashed border-slate-200 p-8 md:p-16">
        <h2 class="text-2xl md:text-3xl font-black uppercase mb-4 md:mb-6 text-[#0d1b2a]">Nichts Passendes dabei?</h2>
        <p class="text-slate-500 font-bold uppercase tracking-widest text-[10px] md:text-xs mb-8 md:mb-10 leading-relaxed max-w-md mx-auto">
            Wir sind immer auf der Suche nach motivierten Menschen. Schick uns eine Initiativbewerbung – wir melden uns.
        </p>
        <a href="mailto:attar.dienstleistungen@gmail.com" class="text-brand font-black uppercase italic text-lg md:text-xl border-b-2 border-brand pb-1 hover:text-[#0d1b2a] hover:border-[#0d1b2a] transition-all break-all">
            attar.dienstleistungen@gmail.com
        </a>
    </div>
  </section>
</Layout>
