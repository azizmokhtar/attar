---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Angebot anfragen">
  <section class="pt-24 pb-12 md:pt-40 md:pb-20 px-6 md:px-24">
    <p class="text-brand font-bold uppercase tracking-[0.3em] mb-4 text-[10px] md:text-xs italic">Kontakt</p>
    <h1 class="text-[clamp(2.5rem,10vw,6rem)] font-black uppercase leading-[0.9] mb-8">
      Projekt <br />
      <span class="stroke-black">Besprechen.</span>
    </h1>
  </section>

  <section class="pb-20 md:pb-32 px-6 md:px-24 grid md:grid-cols-12 gap-10 md:gap-16">

    <div class="md:col-span-4 space-y-8 md:space-y-12">
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-brand mb-4">Direktkontakt</h3>
        <a href="tel:+4915569365960" class="block text-lg md:text-xl font-black uppercase italic hover:text-brand transition-colors mb-2">+49 (0) 15 569 365 96</a>
        <a href="mailto:attar.dienstleistungen@gmail.com" class="block text-base font-black lowercase italic hover:text-brand transition-colors break-all">attar.dienstleistungen@gmail.com</a>
      </div>

      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-brand mb-4">Bürozeiten</h3>
        <p class="text-sm font-bold uppercase leading-relaxed text-slate-500">
          Mo — Fr: 07:00 – 20:00<br/>
          Sa: 08:30 – 18:00
        </p>
      </div>

      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-brand mb-4">Standort</h3>
        <p class="text-sm font-bold uppercase leading-relaxed text-slate-500">
          55606 Kirn<br/>
          Rheinland-Pfalz
        </p>
      </div>
    </div>

    <div class="md:col-span-8 bg-slate-50 p-6 md:p-14 border border-slate-100">
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-8">Schreiben Sie uns – wir melden uns innerhalb von 24 Stunden.</p>
      <form action="https://formspree.io/f/xdalynzd" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

        <div class="flex flex-col gap-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Vollständiger Name *</label>
          <input type="text" name="name" required class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold uppercase text-sm" placeholder="Max Mustermann" />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">E-Mail Adresse *</label>
          <input type="email" name="email" required class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold text-sm" placeholder="email@beispiel.de" />
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Telefonnummer *</label>
          <input
            type="tel"
            name="phone"
            required
            class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold text-sm"
            placeholder="+49 123 456789"
          />
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Gewünschte Dienstleistung</label>
          <select name="service" class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-bold uppercase text-sm cursor-pointer appearance-none">
            <option value="reinigung">Reinigungsservice</option>
            <option value="hausmeister">Hausmeisterservice</option>
            <option value="umzug">Umzugsservice</option>
            <option value="garten">Gartenservice</option>
            <option value="sonstiges">Sonstiges / Allgemein</option>
          </select>
        </div>

        <div class="flex flex-col gap-2 md:col-span-2">
          <label class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-slate-400">Nachricht / Details *</label>
          <textarea name="message" rows="4" required class="bg-transparent border-b-2 border-slate-200 py-2 md:py-3 focus:border-brand outline-none transition-colors font-medium text-sm resize-none" placeholder="Beschreiben Sie Ihr Projekt kurz..."></textarea>
        </div>

        <div class="md:col-span-2 pt-4 md:pt-6">
          <button type="submit" class="w-full bg-[#0d1b2a] text-white py-4 md:py-5 font-black uppercase tracking-[0.2em] hover:bg-brand transition-all flex justify-between px-6 md:px-8 items-center group text-sm">
            Anfrage absenden
            <span class="group-hover:translate-x-2 transition-transform">→</span>
          </button>
        </div>

        <input type="text" name="_gotcha" style="display:none" />
      </form>
    </div>
  </section>
</Layout>
